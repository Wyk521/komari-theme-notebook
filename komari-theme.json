{
  "name": "Komari Notebook 作业本",
  "short": "KomariNotebook",
  "description": "清爽作业本风格的 Komari 主题，支持三列/四列节点卡片、人民币资产概览、清晰资源进度条、分段网络质量、多线路 Ping 与交互式负载图表。",
  "version": "0.8.5",
  "author": "komari主题制作",
  "url": "https://github.com/Wyk521/komari-theme-notebook",
  "preview": "preview.png",
  "configuration": {
    "type": "managed",
    "icon": "/themes/KomariNotebook/dist/assets/notebook.svg",
    "name": {
      "zh-CN": "作业本主题设置",
      "en": "Notebook theme settings"
    },
    "data": [
      {
        "name": {
          "zh-CN": "顶栏文字",
          "en": "Header text"
        },
        "type": "title"
      },
      {
        "key": "notebook_title",
        "name": {
          "zh-CN": "作业本标题",
          "en": "Notebook title"
        },
        "type": "string",
        "default": "服务器作业本"
      },
      {
        "key": "notebook_subtitle",
        "name": {
          "zh-CN": "作业本副标题",
          "en": "Notebook subtitle"
        },
        "type": "string",
        "default": "每一台节点，都是今天要认真检查的一页。"
      },
      {
        "key": "footer_note",
        "name": {
          "zh-CN": "页脚批注",
          "en": "Footer note"
        },
        "type": "string",
        "default": "今日也要认真检查服务器。"
      },
      {
        "name": {
          "zh-CN": "纸张与布局",
          "en": "Paper and layout"
        },
        "type": "title"
      },
      {
        "key": "accent_color",
        "name": {
          "zh-CN": "批改笔颜色",
          "en": "Accent color"
        },
        "type": "select",
        "options": "blue,green,purple,orange,red",
        "default": "blue"
      },
      {
        "key": "paper_tone",
        "name": {
          "zh-CN": "纸张色调",
          "en": "Paper tone"
        },
        "type": "select",
        "options": "warm,white,blue",
        "default": "warm"
      },
      {
        "key": "default_view",
        "name": {
          "zh-CN": "默认节点视图",
          "en": "Default node view"
        },
        "type": "select",
        "options": "cards,table",
        "default": "cards"
      },
      {
        "key": "card_columns",
        "name": {
          "zh-CN": "桌面端卡片列数",
          "en": "Desktop card columns"
        },
        "type": "select",
        "options": "4,3",
        "default": "4",
        "help": {
          "zh-CN": "三列和四列均使用资源 2×2、网络双栏的紧凑排版。",
          "en": "Both modes use compact 2×2 resources and two-column network data."
        }
      },
      {
        "name": {
          "zh-CN": "首页功能",
          "en": "Homepage features"
        },
        "type": "title"
      },
      {
        "key": "show_summary",
        "name": {
          "zh-CN": "显示统计便签",
          "en": "Show summary notes"
        },
        "type": "switch",
        "default": true
      },
      {
        "key": "show_search",
        "name": {
          "zh-CN": "显示搜索框",
          "en": "Show search"
        },
        "type": "switch",
        "default": true
      },
      {
        "key": "show_group_filter",
        "name": {
          "zh-CN": "显示分组筛选",
          "en": "Show group filter"
        },
        "type": "switch",
        "default": true
      },
      {
        "key": "show_tags",
        "name": {
          "zh-CN": "显示节点标签",
          "en": "Show node tags"
        },
        "type": "switch",
        "default": true
      },
      {
        "key": "show_hardware",
        "name": {
          "zh-CN": "显示资源补充信息",
          "en": "Show resource details"
        },
        "type": "switch",
        "default": true,
        "help": {
          "zh-CN": "在 CPU、内存和硬盘指标下方显示型号、核心数与容量信息。",
          "en": "Show model, core count, and capacity details beneath resource meters."
        }
      },
      {
        "key": "refresh_seconds",
        "name": {
          "zh-CN": "实时数据刷新秒数",
          "en": "Live refresh seconds"
        },
        "type": "number",
        "default": 5,
        "help": {
          "zh-CN": "支持 1–60 秒；设置为 1 即每秒请求一次实时数据。",
          "en": "Supports 1–60 seconds; set to 1 to request live data every second."
        }
      }
    ]
  }
}
